# Browser Configuration
CHROME_DRIVER_PATH=
HEADLESS=true
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# Rate Limiting
REQUESTS_PER_MINUTE=30
DELAY_MIN=2.0
DELAY_MAX=8.0
